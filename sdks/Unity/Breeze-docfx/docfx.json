{
  "metadata": [
    {
      "src": [
        {
          "files": ["docfx-project/docfx-helper.csproj"]
        }
      ],
      "dest": "api",
      "filter": "filterConfig.yml"
    }
  ],
  "build": {
    "content": [
      {
        "files": ["api/**.yml"]
      },
      {
        "files": ["toc.yml", "index.md"]
      }
    ],
    "dest": "_site",
    "template": ["default", "modern"],
    "noLangKeyword": false
  }
}
